# Server
PORT=4000
NODE_ENV=production

# JWT
JWT_SECRET=your_strong_jwt_secret_here_min_32_chars

# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/zembile

# Chapa Payment
CHAPA_SECRET_KEY=CHASECK-your-secret-key
CHAPA_PUBLIC_KEY=CHAPUBK-your-public-key
CHAPA_WEBHOOK_SECRET=your-webhook-secret

# URLs (update after deploying)
FRONTEND_URL=https://zembile.vercel.app
ADMIN_URL=https://zembile-admin.vercel.app
API_BASE_URL=https://zembile-api.onrender.com

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
